{
  minimumReleaseAge: "7days",
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:best-practices",
    "group:definitelyTyped",
    "github>aquaproj/aqua-renovate-config#2.12.1",
  ],
  customManagers: [
    {
      customType: "regex",
      description: "Update tool versions pinned in workflow-lint.yml (actionlint, ghalint, pinact, zizmor)",
      managerFilePatterns: ["/^\\.github/workflows/workflow-lint\\.yml$/"],
      matchStrings: [
        // Env-var pins: datasource and depName come from the preceding comment.
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+\\w+?_VERSION: (?<currentValue>v?\\d+\\.\\d+\\.\\d+)",
        // zizmor-action inline pin: depName from the trailing comment.
        "version: (?<currentValue>v?\\d+\\.\\d+\\.\\d+) # renovate: depName=(?<depName>\\S+)",
      ],
      datasourceTemplate: "github-releases",
      versioningTemplate: "semver",
    },
  ],
  packageRules: [
    {
      description: "Group minor and patch updates for production dependencies",
      groupName: "dependencies (non-major)",
      matchManagers: ["npm"],
      matchDepTypes: ["dependencies"],
      matchUpdateTypes: ["minor", "patch", "pin"],
      automerge: true,
      automergeType: "pr",
      minimumReleaseAge: "7 days",
    },
    {
      description: "Group minor and patch updates for dev dependencies",
      groupSlug: "dev-dependencies-non-major",
      groupName: "devDependencies (non-major)",
      matchManagers: ["npm"],
      matchDepTypes: ["devDependencies"],
      matchUpdateTypes: ["minor", "patch", "pin"],
      automerge: true,
      automergeType: "pr",
      minimumReleaseAge: "7 days",
    },
    {
      description: "Group minor, patch, and digest updates for GitHub Actions",
      groupName: "github-actions (non-major)",
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["minor", "patch", "digest", "pinDigest"],
      automerge: true,
      automergeType: "pr",
      minimumReleaseAge: "7 days",
    },
    {
      description: "Group minor and patch updates for workflow tooling",
      groupName: "workflow tooling (non-major)",
      matchManagers: ["custom.regex"],
      matchUpdateTypes: ["minor", "patch", "pin"],
      automerge: true,
      automergeType: "pr",
      minimumReleaseAge: "7 days",
    },
  ],
}
